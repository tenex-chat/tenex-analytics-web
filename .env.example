# TENEX Analytics Web Dashboard — Environment Variables
# Copy this file to .env and adjust values as needed.
# .env is gitignored and should never be committed.

# Optional: Override the default SQLite database path.
# Default: ~/.tenex/analysis.db
# TENEX_DB_PATH=/absolute/path/to/analysis.db

# Optional: Override the dev server port (default: 5173)
# PORT=5173

# Optional: Override the host binding (default: localhost)
# HOST=localhost
